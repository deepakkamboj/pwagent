{
  "$schema": "https://example.com/pwagent.schema.json",

  "provider": {
    "clientName": "pwagent",
    "model": "claude-sonnet-4.5",
    "logLevel": "error",
    "perAgent": {
      "heal":     { "model": "claude-opus-4.5" },
      "triage":   { "model": "claude-opus-4.5" },
      "report":   { "model": "claude-haiku-4.5" },
      "validate": { "model": "claude-haiku-4.5" },
      "s360":     { "model": "claude-sonnet-4-6" }
    }
  },

  "ado": {
    "org": "https://dev.azure.com/<your-org>",
    "project": "<your-project>",
    "defaultRepo": "<your-repo>",

    "_comment_defaults": "defaults applied to every accessibility bug created by pwagent-a11y and pwagent-s360, unless overridden per-repo",
    "defaults": {
      "bugType": "Bug",
      "bugSeverity": "2 - High",
      "baseTags": ["accessibility", "a11y", "automated"],
      "priorityBySlaState": {
        "OutOfSla":       "1 - Critical",
        "ApproachingSla": "2 - High",
        "InSla":          "3 - Medium"
      }
    }
  },

  "identity": {
    "tenantId": "72f988bf-86f1-41af-91ab-2d7cd011db47",
    "adoScope": "499b84ac-1321-427f-aa17-267ca6975798/.default",
    "_comment": "tenantId = Microsoft AAD tenant; adoScope = Azure DevOps API scope. Both used by `az login` / Kusto / ADO REST."
  },

  "kustoClusters": {
    "1es": {
      "url": "https://1es.kusto.windows.net",
      "database": "AzureDevOps",
      "_comment": "ADO test telemetry. Default for `analyze --flakes`."
    },
    "aria": {
      "url": "https://ariav2.kusto.windows.net",
      "database": "AriaBridge",
      "_comment": "Generic Aria v2 bridge for richer flake context when 1es alone isn't enough."
    },
    "powerapps-engineering": {
      "url": "https://kusto.aria.microsoft.com",
      "database": "9e3b07ee31d44eb9aba317884f5e8ad4",
      "displayName": "PowerApps-Engineering",
      "_comment": "Aria cluster for PowerApps test telemetry. Tables: testrun (one row per run), testresult (one row per individual test outcome). Discover schema with `cluster('kusto.aria.microsoft.com').database('9e3b07ee31d44eb9aba317884f5e8ad4').testrun | getschema`."
    },
    "s360": {
      "url": "https://s360prodro.kusto.windows.net",
      "database": "service360db",
      "_comment": "Service 360 Kusto cluster. Used by `pwagent run s360 --scan|--triage|--fix|--report`. Tables: GetActiveActionItems(), KpiMetadata(), GetAliasToOwnedServiceHierarchyMapping(), PeopleHierarchySnapshot_datalake, GetResolvedActionItems()."
    }
  },

  "s360": {
    "adoOrg": "https://dev.azure.com/<your-org>",
    "adoProject": "<your-project>",
    "adoAreaPath": "<your-area-path>",
    "adoIteration": "<your-iteration-path>",
    "defaultAssignee": "<alias>@microsoft.com",
    "repoUrl": "https://github.com/<org>/<repo>",
    "serviceTreeIds": [],
    "_comment": "serviceTreeIds: optional array of ServiceTree GUIDs to restrict --scan/--triage to specific services. Leave empty to query the full alias hierarchy. adoAreaPath example: 'MyOrg\\MyTeam\\Accessibility'. adoIteration example: 'MyOrg\\Sprint 42'."
  },

  "_comment_repos": "One entry per repository. remoteUrl enables auto-detection of org/project from `git remote get-url origin`. ado fields override the top-level ado.org/project for repos that live in a different org (e.g. msazure vs dynamicscrm). productAreas supports monorepos where different subdirs map to different ADO area paths.",
  "repos": [
    {
      "name": "CRM.Client.UnifiedClient",
      "path": "E:/git/CRM.Client.UnifiedClient",
      "type": "ado",
      "defaultBranch": "main",
      "remoteUrl": "https://dynamicscrm.visualstudio.com/OneCRM/_git/CRM.Client.UnifiedClient",
      "ado": {
        "org": "https://dynamicscrm.visualstudio.com",
        "project": "OneCRM",
        "areaPath": "OneCRM\\Client\\UnifiedClient",
        "iteration": "OneCRM\\Current",
        "bugTags": ["accessibility", "a11y", "unified-client"],
        "defaultAssignee": "",
        "serviceTreeId": "",
        "mcpServer": "dynamicscrm-repo"
      }
    },
    {
      "name": "CRM.Client.controls",
      "path": "E:/git/CRM.Client.controls",
      "type": "ado",
      "defaultBranch": "main",
      "remoteUrl": "https://dynamicscrm.visualstudio.com/OneCRM/_git/CRM.Client.controls",
      "ado": {
        "org": "https://dynamicscrm.visualstudio.com",
        "project": "OneCRM",
        "areaPath": "OneCRM\\Client\\Controls",
        "iteration": "OneCRM\\Current",
        "bugTags": ["accessibility", "a11y", "crm-controls"],
        "defaultAssignee": "",
        "serviceTreeId": "",
        "mcpServer": "dynamicscrm-repo"
      }
    },
    {
      "name": "power-platform-ux",
      "path": "E:/git/power-platform-ux",
      "type": "ado",
      "defaultBranch": "main",
      "remoteUrl": "https://msazure.visualstudio.com/OneAgile/_git/power-platform-ux",
      "ado": {
        "org": "https://msazure.visualstudio.com",
        "project": "OneAgile",
        "areaPath": "OneAgile\\Power Platform UX",
        "iteration": "OneAgile\\Current",
        "bugTags": ["accessibility", "a11y", "ppux"],
        "defaultAssignee": "",
        "serviceTreeId": "",
        "mcpServer": "msazure-repo",
        "_comment_productAreas": "sub-directory → area path mapping for monorepo bug routing",
        "productAreas": [
          { "path": "apps/make-powerapps-com",        "areaPath": "OneAgile\\Power Platform UX\\Maker Portal",        "bugTags": ["accessibility", "a11y", "ppux", "maker-portal"] },
          { "path": "packages/one-cds-designer",      "areaPath": "OneAgile\\Power Platform UX\\Modern Data Explorer","bugTags": ["accessibility", "a11y", "ppux", "cds-designer"] },
          { "path": "packages/cds-event-utilities",   "areaPath": "OneAgile\\Power Platform UX\\Modern Data Explorer","bugTags": ["accessibility", "a11y", "ppux", "cds-event-utilities"] },
          { "path": "packages/powerapps-modern-portal","areaPath": "OneAgile\\Power Platform UX\\Maker Portal",       "bugTags": ["accessibility", "a11y", "ppux", "modern-portal"] },
          { "path": "packages/powerapps-ui-common",   "areaPath": "OneAgile\\Power Platform UX\\Maker Portal",       "bugTags": ["accessibility", "a11y", "ppux", "ui-common"] },
          { "path": "packages/powerapps-learn",       "areaPath": "OneAgile\\Power Platform UX\\Maker Portal",       "bugTags": ["accessibility", "a11y", "ppux", "powerapps-learn"] },
          { "path": "packages/powerapps-wizards",     "areaPath": "OneAgile\\Power Platform UX\\Maker Portal",       "bugTags": ["accessibility", "a11y", "ppux", "powerapps-wizards"] }
        ]
      }
    }
  ],

  "schedules": [
    {
      "name": "monitor-daemon",
      "kind": "startup",
      "command": "pwagent run triage --once",
      "logFile": "%USERPROFILE%/.pwagent/logs/scheduler/monitor-{date}.log",
      "enabled": false,
      "_comment": "kind=startup → fires once when the scheduler starts. Use for long-poll watchers, daemons that maintain their own loop."
    },
    {
      "name": "nightly-flake-refresh",
      "kind": "daily",
      "time": "02:00",
      "command": "pwagent run scenario --gaps-only",
      "logFile": "%USERPROFILE%/.pwagent/logs/scheduler/flake-refresh-{date}.log",
      "enabled": false,
      "_comment": "kind=daily → fires at the given HH:mm in local TZ. Replace with kind=cron if you need a non-fixed window."
    },
    {
      "name": "weekly-report",
      "kind": "weekly",
      "weekday": "Friday",
      "time": "17:00",
      "command": "pwagent run report --period weekly",
      "logFile": "%USERPROFILE%/.pwagent/logs/scheduler/weekly-report-{date}.log",
      "enabled": false,
      "_comment": "kind=weekly → once per week. weekday + time both required."
    },
    {
      "name": "monitor-poll-5m",
      "kind": "interval",
      "interval": 5,
      "command": ["gh", "copilot", "ask", "/triage --watch"],
      "logFile": "%USERPROFILE%/.pwagent/logs/scheduler/monitor-poll-{date}.log",
      "enabled": false,
      "_comment": "kind=interval → every N minutes. command may be a string (run via shell) or an argv array (run directly)."
    }
  ],

  "scheduler": {
    "stateDir": "~/.pwagent/scheduler",
    "logDir":   "~/.pwagent/logs/scheduler"
  },

  "tools": {
    "allowlist": ["read", "write", "edit", "bash", "grep", "gh", "az", "npx"]
  },

  "audit": {
    "enabled": true,
    "path": "~/.pwagent/audit/events.jsonl"
  },

  "defaultSurface": "cli"
}
