{
  "name": "@pwagent/cli",
  "version": "0.1.0",
  "description": "Standalone CLI for the pwagent multi-agent Playwright testing system. Squad design, self-contained runtime.",
  "type": "module",
  "bin": {
    "pwagent": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-content.mjs",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js doctor --no-probe --fix",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@bradygaster/squad-cli": "file:../../squad/packages/squad-cli",
    "@github/copilot-sdk": "^0.3.0",
    "commander": "^12.1.0",
    "execa": "^9.5.1",
    "gray-matter": "^4.0.3",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/prompts": "^2.4.9",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "playwright",
    "testing",
    "agent",
    "cli",
    "automation"
  ],
  "license": "MIT"
}
